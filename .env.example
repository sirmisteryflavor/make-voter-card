# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Feature flags
# NEXT_PUBLIC_ENABLE_SHARING=true

# API Keys (add if integrating with external services)
# NEXT_PUBLIC_API_URL=https://api.example.com
